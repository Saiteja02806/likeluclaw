# Server
NODE_ENV=development
PORT=3000
DOMAIN=likelyclaw.com

# Supabase
SUPABASE_URL=https://pbrfftorddhbsujcuclk.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Razorpay (India payment gateway — replaces Stripe)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
RAZORPAY_PLAN_BASIC=plan_...
RAZORPAY_PLAN_PRO=plan_...
RAZORPAY_PLAN_BUSINESS=plan_...

# Encryption
TOKEN_ENCRYPTION_KEY=generate-with-node-e-console-log-require-crypto-randomBytes-32-toString-hex

# OpenClaw Container Settings
OPENCLAW_BASE_PORT=19000
OPENCLAW_IMAGE=openclaw:local
OPENCLAW_PLATFORM_DIR=/opt/claw-platform

# LLM Proxy (token optimization layer between OpenClaw and LLM APIs)
# Set LLM_PROXY_HOST to enable — containers route LLM calls through the proxy
LLM_PROXY_HOST=host.docker.internal
LLM_PROXY_PORT=3100
LLM_PROXY_MAX_HISTORY=20

# Email (SendGrid)
SENDGRID_API_KEY=SG....
FROM_EMAIL=hello@likelyclaw.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://pbrfftorddhbsujcuclk.supabase.co/auth/v1/callback
